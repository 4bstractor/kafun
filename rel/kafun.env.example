# /etc/kafun/kafun.env — copied from this template at deploy time.
#
# Required. Filesystem root for blob storage; the SQLite index DB lands
# at <KAFUN_ROOT>/index.db unless KAFUN_DB is set.
KAFUN_ROOT=/sanzu/objects

# Optional override for the SQLite path. Default: ${KAFUN_ROOT}/index.db.
# KAFUN_DB=/sanzu/objects/index.db

# S3 surface bind. Bind 0.0.0.0 so NPM (or another reverse proxy) can
# reach it; rely on firewall + auth for the LAN security model.
KAFUN_HOST=0.0.0.0
KAFUN_PORT=8333

# Comma-separated allowed access keys. Empty = auth off.
# Generate keys with: openssl rand -hex 10 | tr 'a-f' 'A-F'
KAFUN_KEYS=

# Admin UI bind (Phoenix). Same trust model as the S3 surface; if you
# want extra protection, set KAFUN_ADMIN_PASSWORD.
KAFUN_ADMIN_HOST=0.0.0.0
KAFUN_ADMIN_PORT=8334
KAFUN_ADMIN_USER=admin
# KAFUN_ADMIN_PASSWORD=change-me

# REQUIRED in prod. Stable signing key for the admin UI's session
# cookies — set this once and don't rotate without expecting active
# admin sessions to log out.
# Generate: mix phx.gen.secret  (or `openssl rand -base64 64 | tr -d '\n' | head -c 64`)
KAFUN_ADMIN_SECRET=

# Logging.
KAFUN_LOG_LEVEL=info

# Erlang distribution mode for the release. `sname` lets you `kafun rpc`,
# `kafun remote`, and `kafun stop` from another shell on the same host —
# required for the index-backup cron entry. The cookie must match across
# all rpc clients (just leave it set and forget about it).
RELEASE_DISTRIBUTION=sname
RELEASE_NODE=kafun
RELEASE_COOKIE=change-me-to-a-stable-random-string

# GC tuning. Defaults match what's hard-coded:
#   sweep every hour, abandon multiparts older than 24h, give in-flight
#   blobs 1h before considering them orphans.
KAFUN_GC_INTERVAL_SEC=3600
KAFUN_GC_ABANDON_AFTER_SEC=86400
KAFUN_GC_BLOB_GRACE_SEC=3600
